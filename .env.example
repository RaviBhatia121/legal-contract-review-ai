# Copy to .env and adjust for local use. No secrets belong in this file.

# Deployment mode: local | demo
DEPLOYMENT_MODE=local

# Host ports for docker-compose. Defaults avoid the common 8000/5173 dev-server
# ports so this stack does not collide with other locally running projects.
# Override if 8420/5420 are also in use on your machine.
BACKEND_PORT=8420
FRONTEND_PORT=5420

# --- Backend (see backend/app/core/config.py) ---
# PART2_DATABASE_URL=sqlite+aiosqlite:///./part2.db
# PART2_PLAYBOOK_ID=defense-services-v1
# PART2_MAX_UPLOAD_BYTES=15728640
# PART2_CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# --- Model provider (not called in P0; placeholders for later phases) ---
# PART2_PROVIDER_TYPE=ollama
# PART2_MODEL_NAME=qwen3.6:35b
# PART2_BASE_URL_DISPLAY=configured, hidden

# P3/P8 shared on-prem model runtime:
# - Docker Compose defaults to AI-assisted review using the shared Ollama VM.
# - No Ollama model is pulled or run on this laptop by default.
# - If the VM/model path is unavailable, the app clearly falls back to rules-only review.
# - Override these if the VM address/model changes:
# OLLAMA_BASE_URL=http://<ollama-vm-ip>:11434
# MODEL_NAME=qwen3.6:35b
# OLLAMA_TIMEOUT_S=180
#
# Optional laptop-local fallback only, if the VM is unavailable:
# 1. docker compose --profile local-model up -d ollama
# 2. docker compose exec ollama ollama pull <model>
# 3. OLLAMA_BASE_URL=http://ollama:11434 MODEL_NAME=<model> docker compose up -d --build backend

# --- Retrieval / P4 (not on by default) ---
# PART2_QDRANT_URL=http://qdrant:6333
# PART2_QDRANT_COLLECTION=part2_guidance_v1
# PART2_EMBEDDING_MODEL=qllama/multilingual-e5-small
#
# Optional P4 retrieval setup path (Qdrant stores only authored playbook
# guidance text, never contract content):
# 1. docker compose --profile retrieval up -d qdrant
# 2. docker compose exec ollama ollama pull qllama/multilingual-e5-small
# 3. docker compose exec backend python -m scripts.index_guidance
# 4. docker compose up -d --build backend
# qllama/multilingual-e5-small is a community GGUF quantization of
# intfloat/multilingual-e5-small (MIT); see TECH_STACK_AND_LICENSES.md P4
# spike notes for the verification record.

# --- Qdrant authentication / P6 (optional; unauthenticated by default) ---
# QDRANT_API_KEY=
#
# Setting this alone is NOT enough — verified live that Qdrant treats an
# *empty-string* QDRANT__SERVICE__API_KEY as "configured" and starts
# rejecting unauthenticated requests, so docker-compose.yml deliberately
# does NOT set that env var on the qdrant service by default (only on
# backend, where an empty value is normalized to "no key" in
# backend/app/core/config.py). To actually require auth:
# 1. Set QDRANT_API_KEY here to a real value.
# 2. Add a docker-compose.override.yml:
#      services:
#        qdrant:
#          environment:
#            QDRANT__SERVICE__API_KEY: ${QDRANT_API_KEY}
# 3. docker compose --profile retrieval up -d --build qdrant backend
# See docs/SECURITY_EVIDENCE.md for the tested before/after behavior.

# --- Frontend ---
# VITE_API_BASE_URL=/api/v1
